int main() {
std::setlocale(LC_ALL, "Ukrainian");
srand(static_cast(time(0)));

int size;
std::cout << "Введіть розмір масиву: ";
std::cin >> size;

if (size <= 0) {
    std::cout << "Некоректний розмір масиву!" << std::endl;
    return 1;
}

std::vector<int> array(size);
std::cout << "Згенерований масив: ";
for (int i = 0; i < size; i++) {
    array[i] = rand() % 20;
    std::cout << array[i] << " ";
}
std::cout << std::endl;

int target, newValue;
std::cout << "\nЯке значення бажаєте знайти та замінити? ";
std::cin >> target;
std::cout << "Введіть нове значення: ";
std::cin >> newValue;

bool found = false;
for (int i = 0; i < size; i++) {
    if (array[i] == target) {
        array[i] = newValue;
        found = true;
    }
}

if (found) {
    std::cout << "\nОновлений масив: ";
    for (int val : array) {
        std::cout << val << " ";
    }
    std::cout << std::endl;
} else {
    std::cout << "\nЗначення " << target << " не знайдено в масиві." << std::endl;
}

return 0;
}

int main() {
std::setlocale(LC_ALL, "Ukrainian");
const double PI = 3.14159265358979323846;
const int MAX_DEGREE = 90;

double sinTable[MAX_DEGREE + 1];

for (int deg = 0; deg <= MAX_DEGREE; deg++) {
    double radians = deg * (PI / 180.0);
    sinTable[deg] = sin(radians);
}

std::cout << "=== ТАБЛИЦЯ СИНУСІВ (Крок 1°) ===" << std::endl;
std::cout << "Формат: [Градус]: Значення" << std::endl;
std::cout << "--------------------------------------------------" << std::endl;

for (int deg = 0; deg <= MAX_DEGREE; deg++) {
    std::cout << "[" << std::setw(2) << deg << "]:" 
              << std::fixed << std::setprecision(4) << sinTable[deg] << "  ";
    
    if ((deg + 1) % 10 == 0) {
        std::cout << std::endl;
    }
}
std::cout << std::endl;

return 0;
}
